# Public Appwrite SDK config (used by Nuxt client)
NUXT_PUBLIC_APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
NUXT_PUBLIC_APPWRITE_PROJECT_ID=<PROJECT_ID>
NUXT_PUBLIC_APPWRITE_DATABASE_ID=fsmes
NUXT_PUBLIC_APPWRITE_BUCKET_ID=application_documents

# Public table IDs
NUXT_PUBLIC_APPWRITE_USER_PROFILES_TABLE_ID=user_profiles
NUXT_PUBLIC_APPWRITE_APPLICATIONS_TABLE_ID=applications
NUXT_PUBLIC_APPWRITE_APPLICATION_DOCUMENTS_TABLE_ID=application_documents
NUXT_PUBLIC_APPWRITE_PANEL_REVIEWS_TABLE_ID=panel_reviews
NUXT_PUBLIC_APPWRITE_DECISION_RECORDS_TABLE_ID=decision_records
NUXT_PUBLIC_APPWRITE_STATUS_HISTORY_TABLE_ID=status_history
NUXT_PUBLIC_APPWRITE_ACTIVITY_LOGS_TABLE_ID=activity_logs

# Server admin SDK config (used by Nuxt server routes/scripts)
# Endpoint, project ID, and database ID may fall back to the matching NUXT_PUBLIC_* values.
# APPWRITE_API_KEY remains required for admin operations.
APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=<PROJECT_ID>
APPWRITE_API_KEY=<APPWRITE_API_KEY>
APPWRITE_DATABASE_ID=fsmes
